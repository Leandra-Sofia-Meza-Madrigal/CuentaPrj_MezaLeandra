import java.util.ArrayList;
import java.util.List;
import java.util.Scanner;
/**
 * Write a description of class PrincipalCuenta here.
 * 
 * Leandra Sofía Meza Madrigal - 2025121853
 * @version (a version number or a date)
 */
public class PrincipalCuenta
{
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        List<Cuenta> cuentas = new ArrayList<>();
        int actual = -1; // índice de la cuenta seleccionada

        System.out.println("======================================");
        System.out.println("   Menú Principal - Clase Cuenta");
        System.out.println("======================================");

        boolean salir = false;
        while (!salir) {
            System.out.println("\nMenú principal");
            System.out.println("1)  Crear cuenta");
            System.out.println("2)  Conocer la cantidad de cuentas creadas");
            System.out.println("3)  Listar cuentas");
            System.out.println("4)  Seleccionar cuenta actual");
            System.out.println("5)  Asignar el nombre del cuenta habiente");
            System.out.println("6)  Depositar");
            System.out.println("7)  Retirar ");
            System.out.println("8)  Consultar saldo");
            System.out.println("9)  Consultar estado de la cuenta");
            System.out.println("10) Salir ");
            System.out.print("Opción: ");
            String op = sc.nextLine().trim();
            
            switch (op) {
                case "1": { // Crear Cuenta
                    System.out.print("Nombre de CuentaHabiente (enter para omitir): ");
                    String nombre = sc.nextLine().trim();
                    System.out.print("Saldo inicial: ");
                    String saldoInicial = sc.nextLine().trim();
                    Cuenta cta;
                    double monto;
                    try {
                           monto = Double.parseDouble(saldoInicial);
                        } catch (NumberFormatException e) {
                           System.out.println("Número inválido, se usará 0.0");
                           monto = 0.0;
                        }
                    if (nombre.isEmpty()) {
                        cta = new Cuenta(monto);
                    } else {
                        cta = new Cuenta (nombre,monto);
                    }
                    cuentas.add(cta);
                    actual = cuentas.size() - 1;
                    System.out.println("Cuenta creada y seleccionada (índice " + actual + ").");
                    break;
                }
                case "2": { // Cantidad cuentas
                   if (cuentas.isEmpty()) {
                        System.out.println("No hay cuentas creadas.");
                    } else {
                        System.out.printf ("Cantidad cuentas creadas: %d \n", Cuenta.getCantCuentasCreadas());
                    }
                   break;
                }
                case "3": { // Listar
                    if (cuentas.isEmpty()) {
                        System.out.println("No hay cuentas creadas.");
                    } else {
                        System.out.println("Índice | Código | Saldo disp.");
                        for (int contador = 0; contador < cuentas.size(); contador++) {
                            Cuenta cta = cuentas.get(contador);
                            System.out.printf("  %d    | %s | %.2f%n",
                                    contador,
                                    cta.getCodCuenta(),
                                    cta.getSaldo());
                        }
                    }
                    break;
                }
                case "4": { // Seleccionar
                    if (cuentas.isEmpty()) {
                        System.out.println("Cree una cuenta primero.");
                        break;
                    }
                    System.out.print("Índice de la cuenta a seleccionar: ");
                    String idxS = sc.nextLine().trim();
                    try {
                        int idx = Integer.parseInt(idxS);
                        if (idx >= 0 && idx < cuentas.size()) {
                            actual = idx;
                            System.out.println("Cuenta índice " + actual + " seleccionado.");
                        } else {
                            System.out.println("Índice fuera de rango.");
                        }
                    } catch (NumberFormatException e) {
                        System.out.println("Índice inválido.");
                    }
                    break;
                }
                case "5": { // Asignar nombre
                    if (actual < 0 || cuentas.isEmpty()) {
                        System.out.println("Debe crear y seleccionar una cuenta primero.");
                        break;
                    }
                    Cuenta cta = cuentas.get(actual);
                    System.out.println("Nombre del cuenta habiente:");
                    String nombreC = sc.nextLine().trim();
                    cta.setNombreCuentaHabiente(nombreC);
                    break;
                }
                case "6": { // Depósito
                    if (actual < 0 || cuentas.isEmpty()) {
                        System.out.println("Debe crear y seleccionar una cuenta primero.");
                        break;
                    }
                    System.out.print("Monto a depositar: ");
                    String montoD = sc.nextLine().trim();
                    double deposito;
                    try {
                        deposito = Double.parseDouble(montoD);
                    } catch (NumberFormatException e) {
                        System.out.println("Número inválido, no se realizó el depósito.");
                        break;
                    }
                    deposito = Math.abs(deposito);
                    cuentas.get(actual).depositar(deposito);
                    System.out.printf("Saldo disponible: %.2f%n", cuentas.get(actual).getSaldo());
                    break;
                }
                case "7": { // Retirar
                    if (actual < 0 || cuentas.isEmpty()) {
                        System.out.println("Debe crear y seleccionar una cuenta primero.");
                        break;
                    }
                    System.out.print("Monto a retirar: ");
                    String montoR = sc.nextLine().trim();
                    double retiro;
                    try {
                        retiro = Double.parseDouble(montoR);
                    } catch (NumberFormatException e) {
                        System.out.println("Número inválido, no se realizó el retiro.");
                        break;
                    }
                    cuentas.get(actual).retirar(retiro);
                    System.out.printf("Saldo disponible: %.2f%n", cuentas.get(actual).getSaldo());
                    break;
                }
                case "8": { // Consultar saldo
                    if (actual < 0 || cuentas.isEmpty()) {
                        System.out.println("Debe crear y seleccionar una cuenta primero.");
                        break;
                    }
                    System.out.printf("Saldo disponible: %.2f%n", cuentas.get(actual).getSaldo());
                    break;
                }
                case "9": { // toString
                    if (actual < 0 || cuentas.isEmpty()) {
                        System.out.println("Debe crear y seleccionar una cuenta primero.");
                        break;
                    }
                    System.out.println(cuentas.get(actual).toString());
                    break;
                }
                case "10": {
                    salir = true;
                    System.out.println("¡Hasta luego!");
                    break;
                }
                default:
                    System.out.println("Opción inválida.");
            }
        }
        sc.close();
    }
}
